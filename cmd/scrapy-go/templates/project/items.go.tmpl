package main

// ExampleItem 是一个示例 Item 定义。
// 使用 `json` tag 指定 JSON 序列化字段名。
// 使用 `item` tag 指定 scrapy-go 字段元数据（可选）。
type ExampleItem struct {
	Title       string `json:"title" item:"title"`
	URL         string `json:"url" item:"url"`
	Description string `json:"description,omitempty" item:"description"`
}
