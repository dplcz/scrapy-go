# {{.ProjectName}} scrapy-go 配置文件
#
# 本文件包含 scrapy-go 框架的运行时配置。
# 配置优先级：代码中 Settings > scrapy-go.toml > 框架默认值
#
# 环境变量 SCRAPY_GO_CONFIG 可指定配置文件路径，
# 默认自动加载当前目录下的 scrapy-go.toml。

# ============================================================================
# 基础配置
# ============================================================================

# 项目名称
# bot_name = "{{.ProjectName}}"

# User-Agent 字符串
# user_agent = "{{.ProjectName}} (+http://www.yourdomain.com)"

# ============================================================================
# 并发与限速
# ============================================================================

# 全局最大并发请求数
# concurrent_requests = 16

# 每个域名的最大并发请求数
# concurrent_requests_per_domain = 8

# 同时处理的最大 Item 数量
# concurrent_items = 100

# 下载延迟（秒），0 表示无延迟
# download_delay = 0

# 是否随机化下载延迟（在 0.5*delay ~ 1.5*delay 之间随机）
# randomize_download_delay = true

# ============================================================================
# 下载配置
# ============================================================================

# 下载超时（秒）
# download_timeout = 180

# 最大下载大小（字节），超过此大小的响应将被丢弃，默认 1GB
# download_maxsize = 1073741824

# 下载大小警告阈值（字节），超过此大小会记录警告，默认 32MB
# download_warnsize = 33554432

# ============================================================================
# 重试配置
# ============================================================================

# 是否启用重试
# retry_enabled = true

# 最大重试次数
# retry_times = 2

# 需要重试的 HTTP 状态码
# retry_http_codes = [500, 502, 503, 504, 522, 524, 408, 429]

# ============================================================================
# 重定向配置
# ============================================================================

# 是否启用重定向
# redirect_enabled = true

# 最大重定向次数
# redirect_max_times = 20

# ============================================================================
# Cookies 配置
# ============================================================================

# 是否启用 Cookies（会话保持）
# cookies_enabled = true

# 是否开启 Cookies 调试日志
# cookies_debug = false

# ============================================================================
# HTTP 代理
# ============================================================================

# 是否启用 HTTP 代理中间件
# httpproxy_enabled = true

# ============================================================================
# HTTP 压缩
# ============================================================================

# 是否启用 HTTP 压缩（gzip/deflate）
# compression_enabled = true

# ============================================================================
# 缓存配置
# ============================================================================

# 是否启用 HTTP 缓存
# httpcache_enabled = false

# 缓存目录
# httpcache_dir = "httpcache"

# 缓存过期时间（秒），0 表示永不过期
# httpcache_expiration_secs = 0

# 是否对缓存内容进行 gzip 压缩
# httpcache_gzip = false

# 缓存策略："dummy"（全部缓存）或 "rfc2616"（遵循 HTTP 缓存头）
# httpcache_policy = "dummy"

# ============================================================================
# Robots.txt
# ============================================================================

# 是否遵守 robots.txt
# robotstxt_obey = false

# ============================================================================
# 日志配置
# ============================================================================

# 是否启用日志
# log_enabled = true

# 日志级别：DEBUG、INFO、WARN、ERROR
# log_level = "INFO"

# 日志输出文件（为空则输出到 stderr）
# log_file = ""

# ============================================================================
# 统计配置
# ============================================================================

# 爬虫结束时是否输出统计摘要
# stats_dump = true

# 统计日志输出间隔（秒）
# logstats_interval = 60.0

# ============================================================================
# 断点续爬
# ============================================================================

# 断点续爬目录（设置后启用磁盘队列持久化）
# jobdir = ""

# ============================================================================
# 深度控制
# ============================================================================

# 爬取深度限制，0 表示无限制
# depth_limit = 0

# ============================================================================
# 关闭条件
# ============================================================================

# 累计错误数达到此值时自动关闭爬虫，0 表示不限制
# closespider_errorcount = 0

# 累计采集 Item 数达到此值时自动关闭爬虫，0 表示不限制
# closespider_itemcount = 0

# 累计爬取页面数达到此值时自动关闭爬虫，0 表示不限制
# closespider_pagecount = 0

# 爬虫运行超过此秒数时自动关闭，0 表示不限制
# closespider_timeout = 0

# ============================================================================
# 优雅关闭
# ============================================================================

# 优雅关闭超时时间（秒），超时后强制退出
# graceful_shutdown_timeout = 30

# ============================================================================
# 数据导出
# ============================================================================

# 导出文件路径（为空则不导出）
# feed_uri = ""

# 导出格式：json、jsonlines、csv、xml
# feed_format = ""

# 导出文件编码
# feed_export_encoding = ""

# JSON 导出缩进空格数，0 表示紧凑格式
# feed_export_indent = 0

# ============================================================================
# 调试与监控
# ============================================================================

# 是否启用 pprof HTTP 调试端点
# pprof_enabled = false

# pprof 监听地址
# pprof_addr = ":6060"

# 是否启用内存使用监控
# memusage_enabled = true

# 内存使用上限（MB），超过后关闭爬虫，0 表示不限制
# memusage_limit_mb = 0

# 内存使用警告阈值（MB），超过后记录警告，0 表示不警告
# memusage_warning_mb = 0

