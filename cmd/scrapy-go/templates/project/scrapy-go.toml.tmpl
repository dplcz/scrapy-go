# {{.ProjectName}} scrapy-go 配置文件
#
# 本文件包含 scrapy-go 框架的运行时配置。
# 配置优先级：代码中 Settings > scrapy-go.toml > 框架默认值
#
# 环境变量 SCRAPY_GO_CONFIG 可指定配置文件路径，
# 默认自动加载当前目录下的 scrapy-go.toml。

# ============================================================================
# 基础配置
# ============================================================================

# 项目名称
# bot_name = "{{.ProjectName}}"

# User-Agent 字符串
# user_agent = "{{.ProjectName}} (+http://www.yourdomain.com)"

# ============================================================================
# 并发与限速
# ============================================================================

# 全局最大并发请求数
# concurrent_requests = 16

# 每个域名的最大并发请求数
# concurrent_requests_per_domain = 8

# 下载延迟（秒），0 表示无延迟
# download_delay = 0

# 是否随机化下载延迟
# randomize_download_delay = true

# ============================================================================
# 下载配置
# ============================================================================

# 下载超时（秒）
# download_timeout = 180

# ============================================================================
# 重试配置
# ============================================================================

# 是否启用重试
# retry_enabled = true

# 最大重试次数
# retry_times = 2

# 需要重试的 HTTP 状态码
# retry_http_codes = [500, 502, 503, 504, 522, 524, 408, 429]

# ============================================================================
# 重定向配置
# ============================================================================

# 是否启用重定向
# redirect_enabled = true

# 最大重定向次数
# redirect_max_times = 20

# ============================================================================
# 缓存配置
# ============================================================================

# 是否启用 HTTP 缓存
# httpcache_enabled = false

# 缓存目录
# httpcache_dir = "httpcache"

# 缓存过期时间（秒），0 表示永不过期
# httpcache_expiration_secs = 0

# ============================================================================
# Robots.txt
# ============================================================================

# 是否遵守 robots.txt
# robotstxt_obey = false

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别：DEBUG、INFO、WARN、ERROR
# log_level = "INFO"

# ============================================================================
# 断点续爬
# ============================================================================

# 断点续爬目录（设置后启用磁盘队列持久化）
# jobdir = ""

# ============================================================================
# 深度控制
# ============================================================================

# 爬取深度限制，0 表示无限制
# depth_limit = 0
