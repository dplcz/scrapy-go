// {{.ProjectName}} 项目配置
//
// 本文件定义项目级别的配置，通过 settings.PriorityProject 优先级
// 覆盖框架默认值。Spider 可通过 CustomSettings() 进一步覆盖这些配置。
package project

import (
	"github.com/dplcz/scrapy-go/pkg/settings"
)

// NewProjectSettings 创建并返回项目级别的配置实例。
// 在创建 Crawler 时通过 crawler.WithSettings 传入。
//
// 配置优先级：default(0) < project(20) < spider(30) < cmdline(40)
func NewProjectSettings() *settings.Settings {
	s := settings.New()

	p := settings.PriorityProject

	// ====================================================================
	// 基础配置
	// ====================================================================

	s.Set("BOT_NAME", "{{.ProjectName}}", p)
	// s.Set("USER_AGENT", "{{.ProjectName}} (+http://www.yourdomain.com)", p)

	// ====================================================================
	// 并发与限速
	// ====================================================================

	// 全局最大并发请求数（默认 16）
	s.Set("CONCURRENT_REQUESTS", 16, p)

	// 每个域名的最大并发请求数（默认 8）
	s.Set("CONCURRENT_REQUESTS_PER_DOMAIN", 8, p)

	// 下载延迟（秒），0 表示无延迟
	// s.Set("DOWNLOAD_DELAY", 0, p)

	// ====================================================================
	// 下载配置
	// ====================================================================

	// 下载超时（秒）
	// s.Set("DOWNLOAD_TIMEOUT", 180, p)

	// ====================================================================
	// 重试配置
	// ====================================================================

	// s.Set("RETRY_ENABLED", true, p)
	// s.Set("RETRY_TIMES", 2, p)

	// ====================================================================
	// Robots.txt
	// ====================================================================

	// 是否遵守 robots.txt（默认 true）
	s.Set("ROBOTSTXT_OBEY", true, p)

	// ====================================================================
	// 日志配置
	// ====================================================================

	// 日志级别：DEBUG、INFO、WARN、ERROR（默认 DEBUG）
	s.Set("LOG_LEVEL", "INFO", p)

	// ====================================================================
	// 中间件配置（取消注释以启用/禁用/调整优先级）
	// ====================================================================

	// s.Set("DOWNLOADER_MIDDLEWARES", map[string]int{
	//     // "MyCustomMiddleware": 543,
	// }, p)

	// ====================================================================
	// Pipeline 配置（取消注释以启用）
	// ====================================================================

	// s.Set("ITEM_PIPELINES", map[string]int{
	//     // "MyPipeline": 300,
	// }, p)

	return s
}
