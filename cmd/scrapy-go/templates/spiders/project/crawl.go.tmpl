// Package spiders
// 爬虫: {{.Name}}
// 基于规则的 CrawlSpider，自动提取和跟踪链接。
package spiders

import (
	"context"

	shttp "github.com/dplcz/scrapy-go/pkg/http"
	"github.com/dplcz/scrapy-go/pkg/linkextractor"
	"github.com/dplcz/scrapy-go/pkg/spider"
)

// {{.ClassName}} 基于规则的爬虫实现。
type {{.ClassName}} struct {
	spider.CrawlSpider
}

// New{{.ClassName}} 创建一个新的 {{.ClassName}} 实例。
func New{{.ClassName}}() *{{.ClassName}} {
	s := &{{.ClassName}}{}

	s.SpiderName = "{{.Name}}"
	s.StartURLs = []string{"{{.URL}}"}

	// 定义爬取规则
	s.Rules = []spider.Rule{
		{
			LinkExtractor: linkextractor.NewHTMLLinkExtractor(
				linkextractor.WithAllow(`/items/`),
			),
			Callback: s.parseItem,
		},
	}

	return s
}

// parseItem 解析详情页面。
func (s *{{.ClassName}}) parseItem(ctx context.Context, response *shttp.Response) ([]spider.Output, error) {
	item := map[string]any{
		"url": response.URL.String(),
		// TODO: 在此处提取页面数据
		// "title": response.CSS("h1::text").Get(""),
	}

	return []spider.Output{
		{Item: item},
	}, nil
}

// CustomSettings 返回 Spider 级别的配置覆盖。
// 返回 nil 表示不覆盖任何配置。
func (s *{{.ClassName}}) CustomSettings() *spider.Settings{
    return nil
}